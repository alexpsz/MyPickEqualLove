{
  "name": "mypickequallove",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:equal-love": "node scripts/run-project-command.mjs equal-love dev",
    "dev:nearly-equal-joy": "node scripts/run-project-command.mjs nearly-equal-joy dev",
    "dev:not-equal-me": "node scripts/run-project-command.mjs not-equal-me dev",
    "build": "node scripts/clean-static-export.mjs && next build && node scripts/copy-public-assets.mjs",
    "build:equal-love": "node scripts/run-project-command.mjs equal-love build",
    "build:nearly-equal-joy": "node scripts/run-project-command.mjs nearly-equal-joy build",
    "build:not-equal-me": "node scripts/run-project-command.mjs not-equal-me build",
    "start": "next start",
    "lint": "eslint src scripts next.config.ts eslint.config.mjs postcss.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:data": "python3 scripts/sync-project-discography.py --project equal-love",
    "sync:data:equal-love": "python3 scripts/sync-project-discography.py --project equal-love",
    "sync:data:nearly-equal-joy": "python3 scripts/sync-project-discography.py --project nearly-equal-joy",
    "sync:data:not-equal-me": "python3 scripts/sync-project-discography.py --project not-equal-me",
    "sync:data:all": "npm run sync:data:equal-love && npm run sync:data:nearly-equal-joy && npm run sync:data:not-equal-me",
    "validate:data": "node scripts/validate-project-data.mjs",
    "validate:data:project": "node scripts/validate-project-data.mjs --project"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.3.1"
  }
}
